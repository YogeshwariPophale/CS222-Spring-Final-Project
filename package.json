{
  "name": "proposal-agent-final-project",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch server/index.js",
    "dev:web": "vite --host 127.0.0.1 --port 5174",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "start": "node server/index.js",
    "repair:local": "node scripts/restore-clean-files.mjs",
    "check:app": "node --check server/pdfExport.js && node --check server/pdfProjectExtractor.js && node --check server/proposalGenerator.js && npm run build && npm run smoke:app",
    "smoke:app": "node scripts/smoke-check.mjs"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^1.16.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2"
  },
  "engines": {
    "node": ">=18.18"
  }
}
